<section role="feed">
   <ul>
      <li>
         <img src="/images/image-retro-pcs.jpg" alt="Reviving Retro PCs" width="121" height="154"/>
         <div>
            <p class="counter">01</p>
            <h3><a href="#">Reviving Retro PCs</a></h3>
            <p>What happens when old PCs are given modern upgrades?</p>
         </div>
      </li>
      <li>
         <img src="/images/image-top-laptops.jpg" alt="Top 10 Laptops of 2022" width="121" height="154"/>
         <div>
            <p class="counter">02</p>
            <h3><a href="#">Top 10 Laptops of 2022</a></h3>
            <p>Our best picks for various needs and budgets.</p>
         </div>
      </li>
      <li>
         <img src="/images/image-gaming-growth.jpg" alt="The Growth of Gaming" width="121" height="154"/>
         <div>
            <p class="counter">03</p>
            <h3><a href="#">The Growth of Gaming</a></h3>
            <p>How the pandemic has sparked fresh opportunities.</p>
         </div>
      </li>
   </ul>
</section>

<style>
   @import "../styles/media.css";

   ul {
      display: grid;
      grid-template-rows:  1fr;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
   }

   li {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 1rem;
      font-size: 0.85rem;
   }

   img {
      width: 121px;
      height: 154px;
   }

   h3 {
      font-weight: var(--font-bold);
      font-size: 1.4em;
      padding: 0.5rem 0;

      a, a:visited {
         text-decoration: none;
         color: var(--very-dark-blue);
      }

      a:hover {
         color: var(--soft-red);
      }
   }

   p:first-child {
      color: var(--soft-red);
      font-size: 2.5em;
      font-weight: var(--font-bold);
   }

   p:last-child {
      line-height: 1.3rem;
   }


   @media screen and (--mobile) {
      ul {
         grid-template-rows: repeat(3, 1fr);
         grid-template-columns:  1fr;
      }
   }

   @media screen and (--desktop) {
      ul {
         grid-template-rows:  1fr;
         grid-template-columns: repeat(3, 1fr);
      }
   }
</style>